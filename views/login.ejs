<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= botName %> - WhatsApp Bot</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            position: relative;
            overflow-x: hidden;
        }

        /* Animated Background */
        body::before {
            content: '';
            position: absolute;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 50%);
            animation: rotate 30s linear infinite;
            pointer-events: none;
        }

        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .container {
            width: 100%;
            max-width: 500px;
            position: relative;
            z-index: 10;
            animation: slideUp 0.8s ease;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(50px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 40px;
            box-shadow: 0 30px 70px rgba(0, 0, 0, 0.3);
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 40px 30px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .header::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 60%);
            animation: shine 8s ease-in-out infinite;
        }

        @keyframes shine {
            0%, 100% { transform: translateX(-100%) rotate(45deg); }
            50% { transform: translateX(100%) rotate(45deg); }
        }

        .bot-icon {
            width: 100px;
            height: 100px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            border: 3px solid white;
            transform: rotate(10deg);
            transition: all 0.3s;
            animation: float 3s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: rotate(10deg) translateY(0); }
            50% { transform: rotate(10deg) translateY(-10px); }
        }

        .bot-icon i {
            font-size: 50px;
            color: white;
            filter: drop-shadow(0 5px 15px rgba(0,0,0,0.3));
        }

        .header h1 {
            color: white;
            font-size: 36px;
            margin-bottom: 5px;
            letter-spacing: 1px;
            text-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }

        .header h1 span {
            background: rgba(255, 255, 255, 0.2);
            padding: 5px 15px;
            border-radius: 50px;
            font-size: 14px;
            margin-left: 10px;
            border: 1px solid rgba(255,255,255,0.3);
        }

        .header p {
            color: rgba(255, 255, 255, 0.9);
            font-size: 16px;
        }

        .features {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            justify-content: center;
            margin-top: 20px;
        }

        .feature-tag {
            background: rgba(255, 255, 255, 0.15);
            padding: 8px 18px;
            border-radius: 50px;
            font-size: 13px;
            color: white;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            backdrop-filter: blur(5px);
            border: 1px solid rgba(255,255,255,0.2);
            transition: all 0.3s;
        }

        .feature-tag:hover {
            transform: translateY(-2px);
            background: rgba(255, 255, 255, 0.25);
        }

        .feature-tag i {
            font-size: 14px;
        }

        .content {
            padding: 40px 30px;
        }

        .info-box {
            background: linear-gradient(135deg, #f5f7fa 0%, #e9ecf2 100%);
            border-radius: 25px;
            padding: 30px;
            margin-bottom: 30px;
            text-align: center;
            border: 2px dashed #667eea;
            position: relative;
            overflow: hidden;
        }

        .info-box::before {
            content: '🔰';
            position: absolute;
            top: -20px;
            right: -20px;
            font-size: 100px;
            opacity: 0.1;
            transform: rotate(20deg);
        }

        .info-icon {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            transform: rotate(-5deg);
            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
        }

        .info-icon i {
            font-size: 30px;
            color: white;
        }

        .info-box h3 {
            color: #333;
            margin-bottom: 15px;
            font-size: 22px;
        }

        .info-box p {
            color: #666;
            margin-bottom: 20px;
            line-height: 1.6;
        }

        .steps {
            display: flex;
            justify-content: space-around;
            gap: 10px;
            margin-top: 20px;
        }

        .step {
            flex: 1;
            text-align: center;
        }

        .step-circle {
            width: 40px;
            height: 40px;
            background: #667eea;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 10px;
            color: white;
            font-weight: bold;
            font-size: 18px;
        }

        .step-text {
            font-size: 11px;
            color: #666;
        }

        .input-group {
            margin-bottom: 25px;
        }

        .input-label {
            display: block;
            margin-bottom: 10px;
            color: #555;
            font-weight: 500;
            font-size: 14px;
        }

        .input-label i {
            color: #667eea;
            margin-right: 8px;
        }

        .input-field {
            position: relative;
        }

        .input-field i {
            position: absolute;
            left: 20px;
            top: 50%;
            transform: translateY(-50%);
            color: #667eea;
            font-size: 18px;
            z-index: 1;
        }

        .input-field input {
            width: 100%;
            padding: 18px 20px 18px 50px;
            border: 2px solid #e0e0e0;
            border-radius: 20px;
            font-size: 16px;
            transition: all 0.3s;
            background: white;
        }

        .input-field input:focus {
            border-color: #667eea;
            outline: none;
            box-shadow: 0 0 0 5px rgba(102, 126, 234, 0.1);
            transform: scale(1.02);
        }

        .btn {
            width: 100%;
            padding: 18px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 20px;
            font-size: 18px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            position: relative;
            overflow: hidden;
        }

        .btn::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.3);
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }

        .btn:hover::before {
            width: 300px;
            height: 300px;
        }

        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 20px 30px rgba(102, 126, 234, 0.4);
        }

        .btn:disabled {
            opacity: 0.7;
            cursor: not-allowed;
            transform: none;
        }

        .btn i {
            font-size: 20px;
            z-index: 1;
        }

        .code-container {
            background: #1a1a1a;
            border-radius: 25px;
            padding: 30px;
            margin-top: 30px;
            text-align: center;
            border: 3px solid #667eea;
            display: none;
            animation: pulse 0.8s ease;
        }

        .code-container.show {
            display: block;
        }

        @keyframes pulse {
            0% { transform: scale(0.9); opacity: 0; }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); opacity: 1; }
        }

        .code-title {
            color: #fff;
            margin-bottom: 20px;
            font-size: 18px;
        }

        .code-title i {
            color: #4caf50;
            margin-right: 10px;
        }

        .code-display {
            background: #0a0a0a;
            padding: 20px;
            border-radius: 15px;
            margin: 20px 0;
            border: 2px dashed #4caf50;
            position: relative;
        }

        .code {
            font-size: 48px;
            font-weight: bold;
            letter-spacing: 12px;
            color: #4caf50;
            font-family: 'Courier New', monospace;
            text-shadow: 0 0 20px rgba(76, 175, 80, 0.5);
            word-break: break-all;
        }

        .copy-btn {
            background: #4caf50;
            color: white;
            border: none;
            padding: 10px 25px;
            border-radius: 50px;
            font-size: 14px;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-top: 15px;
            transition: all 0.3s;
            border: 1px solid rgba(255,255,255,0.2);
        }

        .copy-btn:hover {
            background: #45a049;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(76, 175, 80, 0.3);
        }

        .copy-btn i {
            font-size: 16px;
        }

        .code-note {
            color: #999;
            font-size: 14px;
            margin-top: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .code-note i {
            color: #667eea;
        }

        .loader {
            border: 4px solid rgba(255,255,255,0.1);
            border-top: 4px solid #667eea;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 20px auto;
            display: none;
        }

        .loader.show {
            display: block;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            background: #4caf50;
            color: white;
            border-radius: 50px;
            margin-top: 20px;
            font-size: 14px;
            animation: slideIn 0.3s ease;
        }

        .status-badge.warning {
            background: #ff9800;
        }

        .status-badge.error {
            background: #f44336;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .footer {
            text-align: center;
            padding: 25px;
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            color: #666;
            font-size: 14px;
            border-top: 1px solid #e0e0e0;
        }

        .footer a {
            color: #667eea;
            text-decoration: none;
            font-weight: 600;
        }

        .footer i {
            color: #ff4444;
            animation: heartbeat 1.5s ease infinite;
        }

        @keyframes heartbeat {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }

        /* Mobile Responsive */
        @media (max-width: 480px) {
            .header h1 {
                font-size: 28px;
            }
            
            .bot-icon {
                width: 80px;
                height: 80px;
            }
            
            .bot-icon i {
                font-size: 40px;
            }
            
            .code {
                font-size: 32px;
                letter-spacing: 8px;
            }
            
            .steps {
                flex-direction: column;
                gap: 15px;
            }
            
            .step {
                display: flex;
                align-items: center;
                gap: 15px;
                text-align: left;
            }
            
            .step-circle {
                margin: 0;
            }
            
            .copy-btn {
                padding: 8px 20px;
                font-size: 13px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="card">
            <div class="header">
                <div class="bot-icon">
                    <i class="fas fa-robot"></i>
                </div>
                <h1><%= botName %> <span>BOT</span></h1>
                <p><i class="fas fa-bolt"></i> WhatsApp Mini Bot with Device Code Login</p>
                
                <div class="features">
                    <span class="feature-tag"><i class="fas fa-shield-alt"></i> Anti Delete</span>
                    <span class="feature-tag"><i class="fas fa-eye-slash"></i> Anti View Once</span>
                    <span class="feature-tag"><i class="fas fa-download"></i> DP Download</span>
                    <span class="feature-tag"><i class="fas fa-eye"></i> Status Views</span>
                    <span class="feature-tag"><i class="fas fa-heart"></i> Status React</span>
                </div>
            </div>
            
            <div class="content">
                <div class="info-box">
                    <div class="info-icon">
                        <i class="fas fa-mobile-alt"></i>
                    </div>
                    <h3><i class="fas fa-link"></i> Device Code Login</h3>
                    <p>No QR code scanning needed! Just enter your phone number and get an 8-digit code to link your device.</p>
                    
                    <div class="steps">
                        <div class="step">
                            <div class="step-circle">1</div>
                            <div class="step-text">Enter Number</div>
                        </div>
                        <div class="step">
                            <div class="step-circle">2</div>
                            <div class="step-text">Get Code</div>
                        </div>
                        <div class="step">
                            <div class="step-circle">3</div>
                            <div class="step-text">Link Device</div>
                        </div>
                        <div class="step">
                            <div class="step-circle">4</div>
                            <div class="step-text">Start Bot</div>
                        </div>
                    </div>
                </div>
                
                <div class="input-group">
                    <label class="input-label">
                        <i class="fas fa-phone-alt"></i> Your WhatsApp Number
                    </label>
                    <div class="input-field">
                        <i class="fas fa-phone"></i>
                        <input type="text" id="phoneNumber" placeholder="923001234567" value="92300">
                    </div>
                </div>
                
                <button class="btn" onclick="requestCode()" id="requestBtn">
                    <i class="fas fa-qrcode"></i>
                    <span>Generate 8-Digit Code</span>
                </button>
                
                <div class="code-container" id="codeContainer">
                    <div class="code-title">
                        <i class="fas fa-check-circle"></i> Your 8-Digit Code
                    </div>
                    <div class="code-display">
                        <div class="code" id="codeDisplay">--------</div>
                        <button class="copy-btn" onclick="copyCode()" id="copyBtn" style="display: none;">
                            <i class="fas fa-copy"></i> Copy Code
                        </button>
                    </div>
                    <div class="code-note">
                        <i class="fas fa-info-circle"></i>
                        <span>Open WhatsApp → Linked Devices → Link with phone number</span>
                    </div>
                    <div class="loader" id="loader"></div>
                    <div id="statusMessage"></div>
                </div>
            </div>
            
            <div class="footer">
                <p>
                    <i class="fas fa-copyright"></i> 2024 <%= botName %> • 
                    <i class="fas fa-shield"></i> 100% Free • 
                    <i class="fas fa-ban"></i> 0% Band Risk •
                    <i class="fas fa-heart" style="color:#ff4444"></i> Premium Quality
                </p>
            </div>
        </div>
    </div>

    <script>
        let statusCheckInterval = null;

        async function requestCode() {
            const phone = document.getElementById('phoneNumber').value.trim();
            const requestBtn = document.getElementById('requestBtn');
            const codeContainer = document.getElementById('codeContainer');
            const codeDisplay = document.getElementById('codeDisplay');
            const loader = document.getElementById('loader');
            const statusMsg = document.getElementById('statusMessage');
            const copyBtn = document.getElementById('copyBtn');
            
            // Clear any existing interval
            if (statusCheckInterval) {
                clearInterval(statusCheckInterval);
                statusCheckInterval = null;
            }
            
            // Validate phone number
            if (!phone || phone.length < 10) {
                showNotification('❌ Please enter a valid phone number!', 'error');
                return;
            }
            
            if (!/^\d+$/.test(phone)) {
                showNotification('❌ Phone number should contain only digits!', 'error');
                return;
            }
            
            // Disable button
            requestBtn.disabled = true;
            requestBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';
            
            // Show container
            codeContainer.classList.add('show');
            loader.classList.add('show');
            codeDisplay.textContent = '--------';
            if (copyBtn) copyBtn.style.display = 'none';
            statusMsg.innerHTML = '';
            
            try {
                const response = await fetch('/api/request-code', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ phone })
                });
                
                const data = await response.json();
                
                loader.classList.remove('show');
                
                if (data.success) {
                    // Display the REAL 8-digit code
                    codeDisplay.textContent = data.code;
                    if (copyBtn) copyBtn.style.display = 'inline-flex';
                    
                    statusMsg.innerHTML = `
                        <div class="status-badge warning">
                            <i class="fas fa-clock"></i>
                            Waiting for connection... Open WhatsApp and enter this code
                        </div>
                    `;
                    requestBtn.innerHTML = '<i class="fas fa-check"></i> Code Generated';
                    
                    // Start checking connection status
                    const cleanPhone = phone.replace(/\D/g, '');
                    statusCheckInterval = setInterval(async () => {
                        try {
                            const statusRes = await fetch(`/api/status/${cleanPhone}`);
                            const statusData = await statusRes.json();
                            
                            if (statusData.connected) {
                                clearInterval(statusCheckInterval);
                                statusCheckInterval = null;
                                statusMsg.innerHTML = `
                                    <div class="status-badge" style="background:#4caf50">
                                        <i class="fas fa-check-circle"></i>
                                        ✅ Bot Connected Successfully!
                                    </div>
                                `;
                                
                                // Auto hide after 10 seconds
                                setTimeout(() => {
                                    codeContainer.classList.remove('show');
                                    requestBtn.disabled = false;
                                    requestBtn.innerHTML = '<i class="fas fa-qrcode"></i> Generate 8-Digit Code';
                                }, 10000);
                            }
                        } catch (error) {
                            console.error('Status check error:', error);
                        }
                    }, 3000);
                    
                    // Auto timeout after 5 minutes
                    setTimeout(() => {
                        if (statusCheckInterval) {
                            clearInterval(statusCheckInterval);
                            statusCheckInterval = null;
                            codeContainer.classList.remove('show');
                            requestBtn.disabled = false;
                            requestBtn.innerHTML = '<i class="fas fa-qrcode"></i> Generate 8-Digit Code';
                            showNotification('⏰ Code expired. Please generate again.', 'warning');
                        }
                    }, 300000);
                    
                } else {
                    // Error from server
                    requestBtn.disabled = false;
                    requestBtn.innerHTML = '<i class="fas fa-qrcode"></i> Generate 8-Digit Code';
                    codeContainer.classList.remove('show');
                    showNotification('❌ Error: ' + (data.error || 'Failed to generate code'), 'error');
                }
                
            } catch (error) {
                console.error('Request error:', error);
                loader.classList.remove('show');
                requestBtn.disabled = false;
                requestBtn.innerHTML = '<i class="fas fa-qrcode"></i> Generate 8-Digit Code';
                codeContainer.classList.remove('show');
                showNotification('❌ Network error. Please try again.', 'error');
            }
        }

        function copyCode() {
            const code = document.getElementById('codeDisplay').textContent;
            if (code && code !== '--------') {
                navigator.clipboard.writeText(code).then(() => {
                    showNotification('✅ Code copied to clipboard!', 'success');
                }).catch(() => {
                    showNotification('❌ Failed to copy code', 'error');
                });
            }
        }

        function showNotification(message, type = 'info') {
            // You can implement a toast notification here
            // For now, using alert
            alert(message);
        }

        // Clean up on page unload
        window.addEventListener('beforeunload', function() {
            if (statusCheckInterval) {
                clearInterval(statusCheckInterval);
            }
        });
    </script>
</body>
</html>
